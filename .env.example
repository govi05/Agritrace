# MongoDB connection
MONGODB_URI=your_mongodb_connection_string_here

# Blockchain (Hardhat local)
BLOCKCHAIN_RPC_URL=http://127.0.0.1:8545
DEPLOYER_PRIVATE_KEY=your_hardhat_private_key_here

# Edge node signing key
EDGE_NODE_PRIVATE_KEY=your_edge_private_key_here

# Backend server
PORT=3000
JWT_SECRET=your_jwt_secret_here

# NPOP Compliance thresholds (from SC-01)
MAX_PESTICIDE_ML=0
MAX_SOIL_PH=8.0
MIN_SOIL_PH=5.5
